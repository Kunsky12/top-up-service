const PlayFab = require("../playfab");

async function addCoins(playfabId, amount){

    return new Promise((resolve, reject)=>{

        PlayFab.AddUserVirtualCurrency({

            PlayFabId: playfabId,
            VirtualCurrency: "RP",
            Amount: amount

        }, (error, result)=>{

            if(error){
                console.error("PlayFab error:", error);
                return reject(error);
            }

            console.log("Coins added:", amount, "to", playfabId);

            resolve(result);
        });

    });

}

module.exports = { addCoins };
